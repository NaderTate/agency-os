# Claude Code local settings
.claude/settings.local.json

# Secrets, NEVER commit
.env
.env.local
.env.*.local

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# Temp files written by commands (email bodies for send-email.mjs, etc.)
data/tmp/
**/.tmp-*
**/*.tmp.*

# Generated state during normal use of AgencyOS.
# The repo ships empty so anyone who clones it starts clean.
# Templates and seed sidecars (data/onboarding/) ARE tracked.
clients/*.md
!clients/_template.md
team/*.md
!team/_template.md
outputs/proposals/*.md
!outputs/proposals/.gitkeep
